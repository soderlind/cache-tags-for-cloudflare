# Keep Composer/dist installs and release archives lean: exclude dev-only files.
# Runtime files (cache-tags-for-cloudflare.php, src/*.php, build/, languages/,
# readme.txt, README.md, composer.json) are intentionally NOT ignored.

/.github            export-ignore
/.gitattributes     export-ignore
/.gitignore         export-ignore
/.distignore        export-ignore
/.markdownlint.json export-ignore
/admin              export-ignore
/tests              export-ignore
/docs               export-ignore
/node_modules       export-ignore
/.phpunit.cache     export-ignore
/composer.lock      export-ignore
/package.json       export-ignore
/package-lock.json  export-ignore
/phpcs.xml.dist     export-ignore
/phpstan.neon.dist  export-ignore
/phpunit.xml.dist   export-ignore
/vitest.config.js   export-ignore
/CONTEXT-MAP.md     export-ignore
/src/Tagging/CONTEXT.md export-ignore
/src/Purging/CONTEXT.md export-ignore
